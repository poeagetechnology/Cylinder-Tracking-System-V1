rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isApproved() {
      return isAuthenticated() && getUserData().status == 'approved';
    }

    function isSuperAdmin() {
      return isApproved() && getUserData().role == 'superadmin';
    }

    function isAdmin() {
      return isApproved() && (getUserData().role == 'admin' || getUserData().role == 'superadmin');
    }

    function isUser() {
      return isApproved() && getUserData().role == 'user';
    }

    // Settings — readable by all, writable only by superadmin
    match /settings/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Users — admin+ can list/update all; users can read/update safe profile fields on their own
    match /users/{userId} {
      allow list: if isAdmin();
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAdmin() || (
        request.auth.uid == userId &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status', 'approvedBy', 'approvedAt'])
      );
      allow delete: if isSuperAdmin();
    }

    // Cylinders — all approved users can read/write from accessible operational pages
    match /cylinders/{docId} {
      allow read: if isApproved();
      allow write: if isApproved();
    }

    // Gas Types
    match /gasTypes/{docId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    // Fillings — all approved users can read/write; deletes are represented as void metadata in the app
    match /fillings/{docId} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update, delete: if isApproved();
    }

    // Inventory — all approved
    match /inventory/{docId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    // Customers, Suppliers, Vehicles, HR, Expenses — admin only routes
    match /customers/{docId} {
      allow read, write: if isAdmin();
    }
    match /suppliers/{docId} {
      allow read, write: if isAdmin();
    }
    match /vehicles/{docId} {
      allow read, write: if isAdmin();
    }
    match /fuelLogs/{docId} {
      allow read, write: if isAdmin();
    }
    match /employees/{docId} {
      allow read, write: if isAdmin();
    }
    match /attendance/{docId} {
      allow read, write: if isAdmin();
    }
    match /salaries/{docId} {
      allow read, write: if isAdmin();
    }
    match /expenses/{docId} {
      allow read, write: if isAdmin();
    }

    // Purchases — all approved users can read/write from accessible inventory pages
    match /purchases/{docId} {
      allow read, write: if isApproved();
    }

    // Filling Purchases — all approved users can read/write from accessible filling pages
    match /fillingPurchases/{docId} {
      allow read, write: if isApproved();
    }

    // Sales — all approved users can read/write from accessible inventory pages
    match /sales/{docId} {
      allow read, write: if isApproved();
    }

    match /branches/{docId} {
      allow read, write: if isAdmin();
    }

    match /stockTransactions/{docId} {
      allow read, create: if isApproved();
      allow update, delete: if isSuperAdmin();
    }

    match /auditLogs/{docId} {
      allow read: if isAdmin();
      allow create: if isApproved();
      allow update, delete: if false;
    }

    // Areas — admin+ can read; superadmin can write
    match /areas/{docId} {
      allow read: if isAdmin();
      allow write: if isSuperAdmin();
    }

    // Weekly Wages — admin+ can read/write
    match /weeklyWages/{docId} {
      allow read, write: if isAdmin();
    }

    // Movements (Cylinder IN/OUT) — all approved users can read/create/update for accessible inventory pages
    match /movements/{docId} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update, delete: if isApproved();
    }

    // Empty Returns (Customer returns empty cylinders) — all approved users can read/write from accessible inventory pages
    match /emptyReturns/{docId} {
      allow read, write: if isApproved();
    }

    // Load Returns (Fault cylinder returns) — all approved users can read/write from accessible inventory pages
    match /loadReturns/{docId} {
      allow read, write: if isApproved();
    }
  }
}
